    "Slack Notification": {
      "main": [[{ "node": "Respond to Webhook", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "description": "Automates startup evaluation by enriching company data via Crunchbase + LinkedIn + web scraping, synthesising a structured brief using Claude AI, scoring on 5 dimensions, routing to Shortlist/Watch/Archive, writing results to Google Sheets, and alerting Slack for high-scoring startups.",
    "author": "Nithin Rajmohan",
    "version": "1.0.0"
  }
}
