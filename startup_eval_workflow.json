          { "node": "Slack Notification", "type": "main", "index": 0 },
          { "node": "Write to Google Sheets", "type": "main", "index": 0 }
        ],
        [
          { "node": "Write to Google Sheets", "type": "main", "index": 0 }
        ]
      ]
    },
    "Write to Google Sheets": {
      "main": [[{ "node": "Respond to Webhook", "type": "main", "index": 0 }]]
