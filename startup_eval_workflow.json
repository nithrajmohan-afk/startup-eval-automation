      "main": [[{ "node": "Build AI Prompt", "type": "main", "index": 0 }]]
    },
    "Build AI Prompt": {
      "main": [[{ "node": "Claude AI Evaluation", "type": "main", "index": 0 }]]
    },
    "Claude AI Evaluation": {
      "main": [[{ "node": "Parse Score + Route", "type": "main", "index": 0 }]]
    },
    "Parse Score + Route": {
      "main": [[{ "node": "Is Shortlist?", "type": "main", "index": 0 }]]
    },
    "Is Shortlist?": {
      "main": [
